DATABASE_URL="postgresql://cmt:cmt_dev_password@localhost:5432/cmt_dev"
JWT_ACCESS_SECRET="change-me-in-every-real-environment"
JWT_REFRESH_SECRET="change-me-too-and-never-reuse-the-access-secret"
PORT=3001

# Comma-separated browser-origin allowlist for CORS. Unset = allow all (dev only).
# Always set in production, e.g.: https://asiahealthlink.com
CORS_ORIGINS=""

# Optional — without this, EmailService falls back to logging emails to the console
# instead of sending them (see src/common/email/email.service.ts).
# IMPORTANT: the default RESEND_FROM_EMAIL below is Resend's sandbox sender, which can
# ONLY deliver to the Resend account owner's own verified email — never to real users.
# Once RESEND_API_KEY is set, verify a domain in the Resend dashboard and change
# RESEND_FROM_EMAIL to an address on it, or OTP emails will silently fail to arrive.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Asia Health Link & Travel <onboarding@resend.dev>"

# Optional — S3-compatible object storage for uploaded documents (AWS S3, Cloudflare
# R2, Railway Bucket, MinIO...). All three of BUCKET/ACCESS_KEY_ID/SECRET_ACCESS_KEY
# must be set to activate; otherwise files go to ephemeral local disk (dev only).
# Set S3_ENDPOINT for non-AWS providers (e.g. https://<accountid>.r2.cloudflarestorage.com).
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="auto"
S3_ENDPOINT=""

# Optional — real Stripe payments (see src/common/payments/payment-processor.service.ts).
# Without STRIPE_SECRET_KEY, payments are simulated by the documented mock processor
# (any paymentMethodToken "succeeds" except the literal "tok_decline"). In Stripe mode,
# paymentMethodToken must be a real Stripe PaymentMethod id — use Stripe's test cards,
# e.g. "pm_card_visa" (succeeds) / "pm_card_chargeDeclined" (declines), never real card
# data. Get keys from https://dashboard.stripe.com/test/apikeys (use TEST mode keys
# until you are genuinely ready to take real payments).
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# From the webhook endpoint's settings in the Stripe dashboard, or `stripe listen` in
# local dev. Required only to verify POST /v1/payments/webhook/stripe.
STRIPE_WEBHOOK_SECRET=""

# Optional — real SMS/OTP via Twilio (see src/common/sms/sms.service.ts). Without all
# three set, SMS is logged to the console instead of sent. Get these from
# https://console.twilio.com. TWILIO_FROM_NUMBER must be a number you own on Twilio,
# in E.164 format (e.g. "+15551234567").
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
