DATABASE_URL="postgresql://cmt:cmt_dev_password@localhost:5432/cmt_dev"
JWT_ACCESS_SECRET="change-me-in-every-real-environment"
JWT_REFRESH_SECRET="change-me-too-and-never-reuse-the-access-secret"
PORT=3001

# Comma-separated browser-origin allowlist for CORS. Unset = allow all (dev only).
# Always set in production, e.g.: https://china-medical-and-tourism.vercel.app
CORS_ORIGINS=""

# Optional — without this, EmailService falls back to logging emails to the console
# instead of sending them (see src/common/email/email.service.ts).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="China Medical and Tourism <onboarding@resend.dev>"

# Optional — S3-compatible object storage for uploaded documents (AWS S3, Cloudflare
# R2, Railway Bucket, MinIO...). All three of BUCKET/ACCESS_KEY_ID/SECRET_ACCESS_KEY
# must be set to activate; otherwise files go to ephemeral local disk (dev only).
# Set S3_ENDPOINT for non-AWS providers (e.g. https://<accountid>.r2.cloudflarestorage.com).
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="auto"
S3_ENDPOINT=""
