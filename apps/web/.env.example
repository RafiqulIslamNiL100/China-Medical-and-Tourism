NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/v1

# The site's own public origin — used for canonical URLs, Open Graph/Twitter tags,
# and the sitemap. Defaults to http://localhost:3000 if unset, which is only correct
# in local dev. Always set in production, e.g.: https://asiahealthlink.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
