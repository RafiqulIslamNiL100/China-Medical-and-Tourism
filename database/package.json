{
  "name": "@cmt/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema and migrations for the China Medical and Tourism platform.",
  "scripts": {
    "validate": "prisma validate --schema=prisma/schema.prisma",
    "generate": "prisma generate --schema=prisma/schema.prisma",
    "migrate:dev": "prisma migrate dev --schema=prisma/schema.prisma",
    "studio": "prisma studio --schema=prisma/schema.prisma",
    "seed": "node prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "devDependencies": {
    "prisma": "^6.16.0"
  },
  "dependencies": {
    "@prisma/client": "^6.16.0",
    "argon2": "^0.41.1"
  }
}
